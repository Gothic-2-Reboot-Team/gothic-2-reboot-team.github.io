    "nuxt": "4.2.1",
    "vue": "3.5.25",
    "vue-router": "^4.6.3" 
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@iconify-json/lucide": "1.2.79",
    "@types/node": "24.10.1",
    "sass-embedded": "1.93.3",
    "typescript": "5.9.3",
    "vue-tsc": "3.1.6"
  },
  "packageManager": "pnpm@10.33.2"
